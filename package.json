{
  "name": "mcp-whatsapp-web",
  "version": "1.1.0",
  "mcpName": "io.github.mario-andreschak/mcp-whatsapp-web",
  "description": "TypeScript MCP server for WhatsApp using whatsapp-web.js",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-whatsapp-web": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mario-andreschak/mcp-whatsapp-web.git"
  },
  "homepage": "https://github.com/mario-andreschak/mcp-whatsapp-web#readme",
  "bugs": {
    "url": "https://github.com/mario-andreschak/mcp-whatsapp-web/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --no-deprecation dist/index.js",
    "dev": "tsc -w & node --no-deprecation --watch dist/index.js",
    "debug": "npx @modelcontextprotocol/inspector node --no-deprecation --trace-deprecation dist/index.js",
    "lint": "eslint src test",
    "format": "prettier --write src/**/*.ts",
    "cleanup-browsers": "node dist/utils/cleanup-browsers.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts"
  },
  "keywords": [
    "mcp",
    "whatsapp",
    "typescript",
    "whatsapp-web.js"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.19.0",
    "@types/qrcode": "^1.5.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "file-type": "^22.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "typescript": "^5.4.5",
    "whatsapp-web.js": "^1.34.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true,
    "puppeteer@24.38.0": true
  }
}
